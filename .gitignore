# 1. Ignore everything by default
/*

# 2. Basic Allowances
!/.gitignore
!README.md
!BACKLOG.md
!MASTER_PLAN.md
!/templates/
!/.github/
!/.github/workflows/
!/.github/workflows/*
!/.vscode/
.vscode/sftp.json

# 3. Purnukka Stack - Modular Engine (New Structure)
!/mu-plugins/
/mu-plugins/*
# Sallitaan loader ja koko moottorin kansio
!/mu-plugins/purnukka-stack-loader.php
!/mu-plugins/purnukka-stack/
!/mu-plugins/purnukka-stack/**

# 4. Purnukka Config - Security Gate
!/purnukka-config/
# ESTETÄÄN kaikki JSON-tiedostot (asiakasdata)
purnukka-config/*.json