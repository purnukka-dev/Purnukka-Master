# 1. Ignore everything by default
/*

# 2. Allow Purnukka-specific configuration and documentation
!/purnukka-config/
!/.vscode/
!/.gitignore
!README.md
# Sallitaan GitHub Actions -automaatiokansio
!/.github/
!/.github/workflows/
!/.github/workflows/*
# Sallitaan kansio, mutta KIELLETÄÄN sftp-yhteystiedot
!/.vscode/
.vscode/sftp.json
# 3. Allow mu-plugins folder but ignore its general content
!/mu-plugins/
/mu-plugins/*

# 4. EXPLICITLY ALLOW ONLY THE CORE FOUR PLUGINS
!/mu-plugins/purnukka-stack-core.php
!/mu-plugins/purnukka-stack-access-control.php
!/mu-plugins/purnukka-stack-ai-connector.php
!/mu-plugins/purnukka-stack-branding.php
!/mu-plugins/purnukka-stack-checkout-logic.php
!/mu-plugins/purnukka-stack-tax-controller.php
!/templates/